{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(python*)",
            "command": "python3 \"H:/HYPERFOCUSZONE/HperCore/HYPER-SILLs-By-WelshDog/scripts/sills_env_guard.py\"; exit 0",
            "shell": "powershell",
            "timeout": 15,
            "statusMessage": "Checking SILLs env vars..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$j = $input | ConvertFrom-Json; $f = $j.tool_input.file_path; if ($f -match 'skills-registry\\.json|\\.mcp\\.json') { python3 \"H:/HYPERFOCUSZONE/HperCore/HYPER-SILLs-By-WelshDog/scripts/sills_config_validator.py\" $f }",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Validating SILLs config..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"H:/HYPERFOCUSZONE/HperCore/HYPER-SILLs-By-WelshDog/scripts/sills_session_start.py\"",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "HyperFocus Z0ne SILLs session start..."
          },
          {
            "type": "command",
            "command": "python3 \"H:/HYPERFOCUSZONE/HperCore/HYPER-SILLs-By-WelshDog/scripts/sills_broski_xp_reward.py\" --reason session_start",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Awarding BROski$ XP..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"H:/HYPERFOCUSZONE/HperCore/HYPER-SILLs-By-WelshDog/scripts/sills_session_end.py\"",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "HyperFocus Z0ne SILLs session end..."
          },
          {
            "type": "command",
            "command": "python3 \"H:/HYPERFOCUSZONE/HperCore/HYPER-SILLs-By-WelshDog/scripts/sills_broski_xp_reward.py\"",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Awarding BROski$ XP..."
          }
        ]
      }
    ]
  }
}
